# ── Python / Django backend ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
*.pyo
db.sqlite3
.env
venv/
backend/logs/*.json
backend/logs/*.log
backend/medunity/settings/local.py

# Firebase service-account key (server side — never commit)
backend/firebase-credentials.json

# ── Flutter / Dart ─────────────────────────────────────────────────────────
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/.pub-cache/
app/.pub/
app/build/
app/.idea/
app/.vscode/
app/*.iml
app/*.ipr
app/*.iws

# Flutter generated
app/**/generated_plugin_registrant.dart
app/.flutter-plugins
app/.flutter-plugins-dependencies

# Symbolicated logs
app/app.*.symbols
app/app.*.map.json

# Coverage
app/coverage/

# ── Android (generated by flutter create on Windows) ──────────────────────
app/android/.gradle/
app/android/captures/
app/android/local.properties
app/android/key.properties
app/android/keystore.properties
app/android/app/release/
app/android/app/debug/
app/android/app/profile/

# Firebase google-services (download from Firebase Console, never commit)
app/android/**/google-services.json

# iOS (not used — Android only)
app/ios/

# Signing keys
*.jks
*.keystore

# ── OS noise ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
